+    def _reserve_v2(self, hidden_size: int):
+        """V2 branch of reserve: construct ElasticBuffer over a torch PG.
+
+        Under MetaInitMode (TRT-LLM weight-load prepass) the construction is
+        deferred: record the shape and build lazily on the first real call.
+        ElasticBuffer sizes itself from (num_max_tokens_per_rank, hidden,
+        num_topk); with the pinned token ceiling a re-reserve is a no-op
+        unless hidden grows.
+        """
+        if (self.buffer is not None and self._pending_hidden is None
+                and hidden_size <= self._constructed_hidden):
+            return
+        if _in_meta_init_mode():
+            self._pending_hidden = max(hidden_size, self._pending_hidden or 0)
+            return
+        self._construct_v2(max(hidden_size, self._pending_hidden or 0,
+                               getattr(self, "_constructed_hidden", 0)))
+
+    def _construct_v2(self, hidden_size: int):
+        import sys
+        _ensure_torch_dist_from_mpi()
+        import torch.distributed as dist
+        # TRT-LLM splits an EP communicator per (pp_rank, moe_ep_rank). The
+        # seam supports the attention-DP serving layout where the EP group
+        # spans the whole world (pp=1) — the configuration this path is
+        # validated for. Wider layouts need per-group PG plumbing upstream.
+        world_size = dist.get_world_size()
+        if self.comm.Get_size() != world_size:
+            raise RuntimeError(
+                f"[deep-ep-v2-seam] EP split size {self.comm.Get_size()} != "
+                f"world {world_size}: only the pp=1 attention-DP layout is "
+                f"supported by this seam")
+        if getattr(self, "_pg", None) is None:
+            self._pg = dist.new_group(ranks=list(range(world_size)),
+                                      backend="nccl")
+        pg = self._pg
+        gpu_timeout = int(os.environ.get("TRTLLM_DEEP_EP_GPU_TIMEOUT_SECS", "600"))
+        cpu_timeout = int(os.environ.get("TRTLLM_DEEP_EP_CPU_TIMEOUT_SECS", "600"))
+        print(f"[deep-ep-v2-seam] constructing deep_ep.ElasticBuffer "
+              f"(max_tokens/rank={self._max_tokens} hidden={hidden_size} "
+              f"topk={self._num_topk} timeouts={gpu_timeout}s)",
+              file=sys.stderr, flush=True)
+        del self.buffer  # Destruct before Construct
+        self.buffer = ElasticBuffer(
+            group=pg,
+            num_max_tokens_per_rank=self._max_tokens,
+            hidden=hidden_size,
+            num_topk=self._num_topk,
+            use_fp8_dispatch=False,
+            allow_hybrid_mode=True,
+            num_cpu_timeout_secs=cpu_timeout,
+            num_gpu_timeout_secs=gpu_timeout,
+        )
+        self._constructed_hidden = hidden_size
+        self._pending_hidden = None
