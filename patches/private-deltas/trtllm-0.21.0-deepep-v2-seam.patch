+def _ensure_torch_dist_from_mpi():
+    """Bootstrap the default torch.distributed NCCL PG from MPI rendezvous.
+
+    TRT-LLM is MPI-launched and fires MoE buffer reservation before (or
+    without ever) calling torch.distributed.init_process_group. V2
+    ElasticBuffer requires a torch ProcessGroup. Rendezvous:
+      * RANK/WORLD_SIZE from MPI.COMM_WORLD
+      * MASTER_ADDR from env (a cross-node-routable IP) or rank-0 bcast of
+        the local hostname (only valid if hostnames resolve cross-node)
+      * MASTER_PORT from MASTER_PORT or TRTLLM_SHIM_PG_MASTER_PORT (29555)
+    Collective: every rank must reach this before any rank returns.
+    """
+    import socket
+    import sys
+    import torch.distributed as dist
+
+    if dist.is_available() and dist.is_initialized():
+        return
+
+    from mpi4py import MPI
+    comm = MPI.COMM_WORLD
+    rank = comm.Get_rank()
+    world_size = comm.Get_size()
+
+    master_addr = os.environ.get("MASTER_ADDR")
+    if not master_addr:
+        master_addr = socket.gethostname() if rank == 0 else None
+        master_addr = comm.bcast(master_addr, root=0)
+    master_port = os.environ.get("MASTER_PORT") or os.environ.get(
+        "TRTLLM_SHIM_PG_MASTER_PORT", "29555")
+
+    if torch.cuda.is_available():
+        local_rank_env = (os.environ.get("LOCAL_RANK")
+                          or os.environ.get("OMPI_COMM_WORLD_LOCAL_RANK")
+                          or os.environ.get("SLURM_LOCALID"))
+        local_rank = int(local_rank_env) if local_rank_env is not None \
+            else rank % torch.cuda.device_count()
+        torch.cuda.set_device(local_rank)
+
+    print(f"[deep-ep-v2-seam] initializing torch.distributed NCCL PG "
+          f"rank={rank}/{world_size} master={master_addr}:{master_port}",
+          file=sys.stderr, flush=True)
+    dist.init_process_group(backend="nccl",
+                            init_method=f"tcp://{master_addr}:{master_port}",
+                            rank=rank, world_size=world_size)
 
 
