+def get_nccl_comm_handles(group: dist.ProcessGroup) -> list:
+    """
+    Get or create `EP_NUM_COMMS` independent NCCL communicator handles for the given process group.
+
+    Each handle wraps an independent `ncclCommInitRank` communicator (its own `sharedRes`, hence its
+    own GIN progress thread). Striping DeepEP traffic across K handles yields K progress threads. The
+    list is cached separately from `get_nccl_comm_handle`'s single-handle cache.
+
+    `EP_NUM_COMMS` unset or `1` returns exactly `[get_nccl_comm_handle(group)]` (the stock single
+    handle), so the single-comm path is byte-identical to stock.
+
+    Arguments:
+        group: the communication group.
+
+    Returns:
+        handles: a list of `EP_NUM_COMMS` NCCL communicator handles (index 0 is the stock handle).
+    """
+    global _storage
+    cache_key = (group, 'handles')
+    if cache_key in _storage:
+        return _storage[cache_key]
+
+    # Handle 0 is always the stock single handle (preserves the single-comm path exactly).
+    handles = [get_nccl_comm_handle(group)]
+
+    num_comms = int(os.getenv('EP_NUM_COMMS', '1'))
+    for _ in range(num_comms - 1):
+        # Each extra comm needs its own unique ID broadcast from the group root.
+        nccl_unique_ids = [None, ] * group.size()
+        dist.all_gather_object(nccl_unique_ids, _C.get_local_nccl_unique_id(), group)
+        root_unique_id = nccl_unique_ids[0]
+        handles.append(NCCLCommHandle(
+            _C.create_nccl_comm(root_unique_id, group.size(), group.rank()), True))
+
+    _storage[cache_key] = handles
+    return handles
+
+
